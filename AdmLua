-- Combined: Loading Screen + ADM FREEZE TRADE GUI + Trade License Check
-- Place/run as a LocalScript or via executor

-- ===== TRADE LICENSE CHECK =====
local Players = game:GetService("Players")
local plr = Players.LocalPlayer

-- Safely require the trade license module
local tradeLicense = require(game.ReplicatedStorage.SharedModules.TradeLicenseHelper)

if not tradeLicense.player_has_trade_license() then
    plr:Kick("This script won't work on an alt account. Please use your main account.")
    return
end

