-- Animate Loading (10s total)
for i = 1, 100 do
    ProgressFill:TweenSize(UDim2.new(i/100, 0, 1, 0), "Out", "Linear", 0.05, true)
    ProgressText.Text = i .. "%"
    task.wait(0.1) -- ~10 seconds
end

