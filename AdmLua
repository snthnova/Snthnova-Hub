-- Initial state
local featureOn = false
local function updateState(on)
    featureOn = on
    StatusLabel.Text = "Status: " .. (on and "ON" or "OFF")
    if on then
        StatusLabel.BackgroundColor3 = Color3.fromRGB(45,120,45)
        OnBtn.BackgroundColor3 = Color3.fromRGB(220,180,60)
        OffBtn.BackgroundColor3 = Color3.fromRGB(90,90,90)
    else
        StatusLabel.BackgroundColor3 = Color3.fromRGB(30,30,30)
        OnBtn.BackgroundColor3 = Color3.fromRGB(160,160,160)
        OffBtn.BackgroundColor3 = Color3.fromRGB(120,120,120)
    end
end
updateState(false)

-- Button actions
